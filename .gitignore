# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*

# Yarn (keep config/plugin files, ignore cache)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Bun
bun.lock
.bun/

# ─── Build Outputs ────────────────────────────────────────────────────────────
/.next/
/out/
/build
/dist

# ─── Testing ─────────────────────────────────────────────────────────────────
/coverage
*.snap

# ─── Environment & Secrets ───────────────────────────────────────────────────
# Commit .env.example; ignore all real env files
.env
.env.*
!.env.example

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Debug & Logs ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*
*.log

# ─── OS & Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# VSCode (keep shared settings, ignore local overrides)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains IDEs
.idea/
*.iml

# ─── Deployment ──────────────────────────────────────────────────────────────
.vercel

# ─── AI / Agent Tooling ──────────────────────────────────────────────────────
.opencode/
.github/
.agents/

# ─── Docs builded by AI ──────────────────────────────────────────────────────
docs/

# ─── Files for Dev ──────────────────────────────────────────────────────
public/
